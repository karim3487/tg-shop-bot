# ─── Telegram ────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ─── PostgreSQL ──────────────────────────────────────────
POSTGRES_DB=tg_shop
POSTGRES_USER=tg_shop_user
POSTGRES_PASSWORD=strongpassword

# ─── Redis ───────────────────────────────────────────────
REDIS_PASSWORD=redispassword
REDIS_USERNAME=default

# ─── MinIO ───────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=media
MINIO_PUBLIC_URL=http://localhost:9000/media

# ─── Django ──────────────────────────────────────────────
SECRET_KEY=your-django-secret-key-here
DJANGO_SETTINGS_MODULE=config.settings.production

# ─── pgAdmin ─────────────────────────────────────────────
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=adminpassword

# ─── WebApp & Bot ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api
# URL вашего WebApp (нужен HTTPS для работы внутри Telegram). 
# Для локального тестирования запустите zrok/ngrok на порту 3000
WEBAPP_URL=https://<your-tunnel-id>.share.zrok.io

# ─── CORS & Security ─────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1,admin
CSRF_TRUSTED_ORIGINS=http://localhost:8000
